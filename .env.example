# ai-governance-checker — environment template
# Every key is optional. The rules-only mode runs without any of them.

# Anthropic Claude API for the LLM-as-judge path.
# https://console.anthropic.com/. Without this, the judge module first
# attempts a local Ollama fallback; without that either, judging is
# disabled and the report runs in rules-only mode.
ANTHROPIC_API_KEY=

# Anthropic model id used by the judge. Defaults to claude-haiku-4-5
# which is the cheapest model with structured-output support.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Local Ollama base URL (no key needed). If a local Ollama daemon is
# running and serving the configured model, the judge module will use
# it when ANTHROPIC_API_KEY is unset.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:1b
